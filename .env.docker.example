# MySQL Configuration
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=omcp_db
DB_USERNAME=omcp_user
DB_PASSWORD=omcp_pass
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_DATABASE=omcp_db
MYSQL_USER=omcp_user
MYSQL_PASSWORD=omcp_pass

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Laravel Configuration
APP_NAME=OMCP
APP_ENV=local
APP_DOMAIN=omcp.localhost
APP_KEY=GENERATE_A_KEY
APP_DEBUG=true
APP_URL=http://api.${APP_DOMAIN}

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@${APP_DOMAIN}"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit UI Authentication
MAILPIT_UI_USERNAME=admin
MAILPIT_UI_PASSWORD=password

QUEUE_CONNECTION=redis
RUN_QUEUE_WORKER=true

SUPER_ADMIN_EMAIL=admin@admin.com
SUPER_ADMIN_PASSWORD=changePASS

# Website Configuration
NEXT_PUBLIC_API_BASE_URL=http://api.${APP_DOMAIN}/api
NEXT_PUBLIC_IMAGE_BASE_URL=http://${APP_DOMAIN}/storage

# Google Cloud Storage Configuration (Required if USE_BASSET_CLOUD=true)
USE_BASSET_CLOUD=false
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_STORAGE_API_URI=
GOOGLE_CLOUD_HMAC_ACCESS_ID=
GOOGLE_CLOUD_HMAC_SECRET=

SESSION_SECURE_COOKIE=false

# Traefik HTTP Basic Auth (dashboard, PhpMyAdmin, Mailpit). Run with: docker compose --env-file .env.docker up -d
# Generate hash: htpasswd -nb user password (use part after colon) or openssl passwd -apr1. Escape $ as $$ in this file.
TRAEFIK_BASIC_AUTH_USER=admin
TRAEFIK_BASIC_AUTH_HASH=your_htpasswd_hash_escape_dollars

# PhpMyAdmin (configuration storage and 2FA are created automatically from ./dbms on first run)
PMA_UPLOAD_LIMIT=256M
PMA_CONTROLPASS=pmapass