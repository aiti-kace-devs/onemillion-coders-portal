{
    "name": "laravel/laravel",
    "type": "project",
    "description": "One Million Coders Program",
    "keywords": [
        "framework",
        "laravel",
        "API",
        "statamic"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "backpack/crud": "^7.0",
        "backpack/filemanager": "^4.0",
        "backpack/permissionmanager": "^7.2",
        "backpack/pro": "^3.0",
        "backpack/theme-tabler": "^2.0",
        "consoletvs/charts": "^6.8",
        "doctrine/dbal": "^3.9",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^2.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "league/commonmark": "^2.6",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "predis/predis": "*",
        "propaganistas/laravel-phone": "^5.3",
        "qirolab/laravel-themer": "^2.0",
        "rbdwllr/reallysimplejwt": "^5.0",
        "spatie/laravel-csp": "^2.10",
        "spatie/laravel-google-cloud-storage": "^2.3",
        "spatie/laravel-permission": "^6.16",
        "spatie/laravel-query-builder": "^6.3",
        "stackkit/laravel-google-cloud-tasks-queue": "^5.0",
        "statamic-rad-pack/runway": "^8.5",
        "statamic/cms": "^5.58",
        "statamic/eloquent-driver": "^4.30",
        "tightenco/ziggy": "^2.5",
        "yajra/laravel-datatables-oracle": "^12.1",
        "backpack/tinymce-field": "^1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "laravel/horizon": "^5.31",
        "backpack/generators": "^4.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Constants.php",
            "app/Helpers/MailerHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pre-update-cmd": [
            "Statamic\\Console\\Composer\\Scripts::preUpdateCmd"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan statamic:install --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.backpackforlaravel.com/"
        }
    ]
}
