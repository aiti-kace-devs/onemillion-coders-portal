upstream phpfpm {
server 127.0.0.1:9000;
}

server {
listen 8080 default_server;
listen [::]:8080 default_server;

root /var/www/html/public;
index index.html index.htm index.php;
server_name _;
charset utf-8;
client_max_body_size 2048M;

access_log /dev/stdout fly;

# CRITICAL FIX: Increase buffer sizes for large headers
# These handle your massive CSP, Link headers, and cookies
large_client_header_buffers 4 32k; # Allow larger request headers

# FastCGI buffer fixes (MOST IMPORTANT)
fastcgi_buffers 32 64k; # Increased from 16 16k to 32 64k (2MB total)
fastcgi_buffer_size 256k; # Increased from 32k to 256k (handles headers)
fastcgi_busy_buffers_size 512k; # Add this for large responses
fastcgi_temp_file_write_size 512k; # Add this

# Proxy buffers (if you're proxying anywhere)
proxy_buffer_size 256k;
proxy_buffers 32 64k;
proxy_busy_buffers_size 512k;

location / {
try_files $uri $uri/ /index.php?$query_string;
}

location ~ \.php$ {
include snippets/fastcgi-php.conf;
fastcgi_param HTTP_X_FORWARDED_FOR $http_fly_client_ip;

# Apply the increased buffers to PHP requests
fastcgi_buffers 32 64k;
fastcgi_buffer_size 256k;
fastcgi_busy_buffers_size 512k;
fastcgi_temp_file_write_size 512k;

fastcgi_pass phpfpm;
}

# Rest of your configuration remains the same...
location = /favicon.ico {
log_not_found off;
access_log off;
}

location = /robots.txt {
log_not_found off;
access_log off;
}

location ~* \.(?:css(\.map)?|js(\.map)?|jpe?g|png|gif|ico|cur|heic|webp|tiff?|mp3|m4a|aac|ogg|midi?|wav|mp4|mov|webm|mpe?g|avi|ogv|flv|wmv)$ {
expires 7d;
access_log off;
log_not_found off;
try_files $uri /index.php?$query_string;
}

location ~* \.(?:svgz?|ttf|ttc|otf|eot|woff2?)$ {
add_header Access-Control-Allow-Origin "*";
expires 7d;
access_log off;
}

location ~ /\.(?!well-known) {
deny all;
}

# IMPORTANT: Remove duplicate headers (your Nginx is adding these)
# But Laravel/backend already sends them, causing duplicates
# Comment these out or change to 'off' for headers already sent by Laravel
add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-Content-Type-Options "nosniff" always;
add_header Referrer-Policy "no-referrer-when-downgrade" always;
}