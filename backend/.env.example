# Partner sync monitoring / alert thresholds
PARTNER_SYNC_MONITORING_ENABLED=true
PARTNER_SYNC_FAILURE_WINDOW_MINUTES=60
PARTNER_SYNC_MIN_ATTEMPTS_FOR_ALERT=20
PARTNER_SYNC_FAILURE_RATE_THRESHOLD=0.35
PARTNER_SYNC_DEFAULT_SLA_HOURS=6
# JSON map by partner_code, e.g. {"startocode":6,"google":4}
# PARTNER_SYNC_PARTNER_SLA_HOURS={}

# Partner progress history: daily rollups + prune cold raw rows (partner:prune-history, scheduled 02:30)
PARTNER_HISTORY_RETENTION_ENABLED=true
PARTNER_HISTORY_HOT_DAYS=90
PARTNER_HISTORY_PRUNE_BATCH=1000
PARTNER_HISTORY_VIZ_POINT_LIMIT=180

# Partner progress (operational only — connection/auth/base URL live in Admin → Partner integrations)
# Bundled Startocode driver slug; must match programme provider + Partner Integration (Admin App Config overrides).
PARTNER_PROGRESS_STARTOCODE_PARTNER_CODE=startocode
PARTNER_PROGRESS_PROGRAM_SLUG=gh-program
# Optional JSON map partner_code => program slug for bulk sync (when partners differ)
# PARTNER_PROGRESS_PROGRAM_SLUGS_JSON={"acme":"acme-program","startocode":"gh-program"}
PARTNER_PROGRESS_BULK_PER_PAGE=100
# Default 3; override via Admin → System Settings → app config PARTNER_PROGRESS_STALE_AFTER_DAYS (integer).
PARTNER_PROGRESS_STALE_AFTER_DAYS=3
PARTNER_PROGRESS_PREVIEW_REFRESH_MINUTES=30
PARTNER_PROGRESS_HISTORY_MIN_GAP_HOURS=12
PARTNER_PROGRESS_ENABLE_STUDENT_MENU=true
PARTNER_PROGRESS_SEND_STALE_REMINDERS=true
PARTNER_PROGRESS_REMINDER_COOLDOWN_HOURS=24
PARTNER_PROGRESS_REMINDER_BATCH_SIZE=200
# Comma-separated partner_code slugs: HMAC secret may be supplied in Headers JSON under a *Signature* header name (see runbook).
# PARTNER_PROGRESS_SIGNATURE_SECRET_HEADER_PARTNER_CODES=startocode,telecel
# PARTNER_PROGRESS_ALLOW_PROBE_OVERRIDE=false
# Optional: php artisan partner:probe-http startocode --omcp=001-26-00015 --ps-secret=ps_...
# PARTNER_PROBE_PS_SECRET=

# Optional endpoint presets for Partner Integration admin wizard
# PARTNER_ENDPOINT_PRESETS_JSON={
